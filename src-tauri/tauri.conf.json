{
  "productName": "Musizer",
  "version": "1.0.0",
  "identifier": "com.dxd.musizer",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420/",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Musizer",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {}
}